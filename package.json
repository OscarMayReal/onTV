{
  "name": "ontv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:renderer": "vite build",
    "rebuild:native": "node scripts/rebuild-better-sqlite3.mjs",
    "dist": "npm run build:renderer && npm run rebuild:native && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron electron.js --enable-features=UseOzonePlatform --ozone-platform=wayland"
  },
  "dependencies": {
    "@ecobridge.xyz/devicemanager": "^3.1.0",
    "@iptv/playlist": "^1.2.1",
    "@jellyfin/sdk": "^0.0.0-unstable.202512091852",
    "@please/lrud": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/config": "^7.4.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.3.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "handtrackjs": "^0.1.5",
    "justwatch-api-client": "^1.0.4",
    "lucide-react": "^0.562.0",
    "m3u-parser-generator": "^5.0.2",
    "mdns-listener-advanced": "^3.4.8",
    "mediasoup": "^3.19.14",
    "node-ble": "^1.13.0",
    "node-wifi": "^2.0.16",
    "prisma": "^7.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-player": "^3.4.0",
    "react-virtuoso": "^4.18.1",
    "react-window": "^2.2.6",
    "tailwindcss": "^4.1.18",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "node-gyp": "^12.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0"
  },
  "main": "electron.js",
  "build": {
    "appId": "com.ontv.app",
    "productName": "OnTV",
    "npmRebuild": false,
    "files": [
      "dist/**",
      "electron.js",
      "preload.js",
      "streamClient.ts",
      "src/generated/prisma/**",
      "src/lib/**",
      "backend/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
